{
  "manifest_version": 3,
  "name": "OpenCLI-Py",
  "version": "0.1.0",
  "description": "Browser automation bridge for opencli-py",
  "permissions": [
    "debugger",
    "tabs",
    "cookies",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "OpenCLI-Py"
  }
}
